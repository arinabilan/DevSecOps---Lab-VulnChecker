# ============================================================
# Credenciales de todos los sistemas - VulnChecker DevSecOps
# Copia a .env y sustituye los valores. No subas .env al repositorio.
# En producción usa contraseñas fuertes y únicas.
# ============================================================

# --- Base de datos de la aplicación (PostgreSQL: vuln-db) ---
# Usado por: db, backend
DB_USERNAME=admin
DB_PASSWORD=secret_pass

# --- Grafana (puerto 3000) ---
# Usado por: grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Grafana detrás de HTTPS (opcional): true/false
# GF_COOKIE_SECURE=false
# GF_HSTS=false

# --- SonarQube y su base de datos (puerto 9000) ---
# Usado por: sonarqube, sonar-db (usuario de la BD es siempre "sonar")
# El usuario admin de la interfaz web se configura en el primer acceso a SonarQube.
SONAR_DB_PASSWORD=sonar

# --- Jenkins (puerto 8081) ---
# Jenkins no usa variables aquí: el usuario admin se crea en el primer acceso.
# La contraseña inicial se muestra en: docker logs vuln-jenkins

# --- OWASP Dependency Check (pipeline Jenkins) ---
# Opcional. API key de NVD (nvd.nist.gov → Request API Key) para evitar rate limit 429.
# Si está aquí, el pipeline la usa; si no, puedes pasarla como parámetro NVD_API_KEY en el job.
# NVD_API_KEY=tu-api-key-aqui

# --- Ejecución local del backend (opcional) ---
# Si corres el backend fuera de Docker, host de la BD (p. ej. localhost o db)
# DB_O_LOCALHOST=localhost
